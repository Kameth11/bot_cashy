# Token provisto por BotFather en Telegram
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Tu ID numérico de Telegram (puedes obtenerlo escribiéndole a @userinfobot)
AUTHORIZED_USER_ID=123456789

# El ID que aparece en la URL de tu Google Sheet (https://docs.google.com/spreadsheets/d/AQUI_ESTA_EL_ID/edit)
SPREADSHEET_ID=tu_spreadsheet_id_aqui

# Credenciales de la Service Account de Google Cloud
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com

# Pega la clave privada EXACTAMENTE como te la da Google (usualmente incluye \n al final de la línea)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvwIBADANBgkqhkiG9w0B... (TU CLAVE COMPLETA) ...\n-----END PRIVATE KEY-----\n"

# Emails autorizados (separados por coma)
ALLOWED_EMAILS=email1@empresa.com,email2@empresa.com

# (Opcional) Cotización default del dólar
# COTIZACION_DEFAULT=1250

# Google AI Studio API Key para NLP (Gemini)
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Modelo de Gemini para texto
# Recomendado por costo: gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash-lite

# Modelo de Gemini para vision / lectura de agendas
# Recomendado: gemini-2.5-flash
# Alternativas: gemini-2.5-flash-lite, gemini-2.5-pro
GEMINI_VISION_MODEL=gemini-2.5-flash

# ===== SUPABASE (Base de datos) =====
# Requerido si USE_SUPABASE=true
# Obtener en: https://supabase.com -> Settings -> API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Recomendado para el bot/backend. No usar en frontend público.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Activar uso de Supabase como base de datos (en vez de Google Sheets)
# false = usa Google Sheets (default), true = usa Supabase
USE_SUPABASE=false

# ===== DASHBOARD API =====
# Puerto donde escucha la API del dashboard (default: 3001)
# DASHBOARD_API_PORT=3001

# Origen(es) permitidos para CORS (separados por coma)
# En desarrollo: http://localhost:5173 (Vite dev server)
# En producción: el dominio real del dashboard
DASHBOARD_ORIGINS=http://localhost:5173

# Secreto para firmar los JWT del dashboard. REQUERIDO — el bot no arranca sin esto.
# Generar uno propio, por ejemplo con: openssl rand -hex 32
JWT_SECRET=
